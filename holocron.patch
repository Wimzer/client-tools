+			{
+				CuiKnowledgeBaseManager::StringKBNode * const sn =
+					static_cast<CuiKnowledgeBaseManager::StringKBNode *>(child);
+				if (sn->m_string.isValid())
+					IGNORE_RETURN(sn->m_string.localize());
+			}
+			warmBodyStringsRecursive(child);
+		}
+	}
+}
