+		for (std::vector<CuiKnowledgeBaseManager::BaseKBNode *>::const_iterator it = node->m_children.begin();
+		     it != node->m_children.end(); ++it)
+		{
+			CuiKnowledgeBaseManager::BaseKBNode * const child = *it;
