+	getCodeDataObject(TUIButton,    m_buttonReportPlayer,"buttonReportPlayer");
+	getCodeDataObject(TUIButton,    m_buttonSample,      "buttonSample");
+	getCodeDataObject(TUIText,      m_textSample,        "textSample");
